FROM lukemathwalker/cargo-chef:latest-rust-1-bookworm AS builder
WORKDIR /build
RUN apt-get update && apt-get install -y --no-install-recommends protobuf-compiler libprotobuf-dev && rm -rf /var/lib/apt/lists/*
COPY . .
COPY models/ models/
ARG BUILD_GIT_HASH=unknown
ENV BUILD_GIT_HASH=${BUILD_GIT_HASH}
# Shared arch-scoped target/ cache mount; the binary and the model files baked
# from target/ are copied out of the mount to /build/out/ for the runner stage.
# See .claude/rules/docker.md "Shared target/ cache mount".
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/build/target,id=bobby-target-arm64,sharing=locked \
    cargo build --release -p skeet-prune --bin pruner && \
    mkdir -p /build/out && \
    cp target/release/pruner /build/out/pruner && \
    BPK_PATH=$(find /build/target/release/build -name "face_detection_yunet_2023mar_opset16.bpk" -print -quit) && \
    cp "$BPK_PATH" /build/out/weights.bpk && \
    echo "$BPK_PATH" > /build/out/bpk_original_path && \
    cp /build/models/text-detection.rten /build/out/text-detection.rten && \
    cp /build/models/text-recognition.rten /build/out/text-recognition.rten

FROM debian:bookworm-slim AS runner
LABEL org.opencontainers.image.source=https://github.com/mikemoraned/bobby
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/out/pruner /usr/local/bin/pruner

# Restore the .bpk weights file to the exact path the binary expects
COPY --from=builder /build/out/weights.bpk /tmp/weights.bpk
COPY --from=builder /build/out/bpk_original_path /tmp/bpk_original_path
RUN mkdir -p "$(dirname "$(cat /tmp/bpk_original_path)")" && \
    cp /tmp/weights.bpk "$(cat /tmp/bpk_original_path)" && \
    rm /tmp/weights.bpk /tmp/bpk_original_path

# Restore the .rten text-detection models to the paths the binary expects
COPY --from=builder /build/out/text-detection.rten /build/models/text-detection.rten
COPY --from=builder /build/out/text-recognition.rten /build/models/text-recognition.rten

COPY config/prune.toml /etc/bobby/prune.toml

CMD ["pruner", "--config-path", "/etc/bobby/prune.toml"]
