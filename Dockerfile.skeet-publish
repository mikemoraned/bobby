FROM lukemathwalker/cargo-chef:latest-rust-1-bookworm AS builder
WORKDIR /build
RUN apt-get update && apt-get install -y --no-install-recommends protobuf-compiler libprotobuf-dev && rm -rf /var/lib/apt/lists/*
COPY . .
# Shared arch-scoped target/ cache mount; binary copied out of the mount to
# /build/out/. See .claude/rules/docker.md "Shared target/ cache mount".
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/build/target,id=bobby-target-arm64,sharing=locked \
    cargo build --release -p skeet-publish --bin skeet-publish && \
    mkdir -p /build/out && \
    cp target/release/skeet-publish /build/out/skeet-publish

FROM debian:bookworm-slim AS runner
LABEL org.opencontainers.image.source=https://github.com/mikemoraned/bobby
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/out/skeet-publish /usr/local/bin/skeet-publish
COPY config/refine.toml /etc/bobby/refine.toml

CMD ["skeet-publish", "--model-path", "/etc/bobby/refine.toml"]
